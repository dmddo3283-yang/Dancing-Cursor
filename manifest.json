{
  "manifest_version": 3,
  "name": "Mirrorball Cursor",
  "description": "소리를 감지하면 마우스 포인터가 미러볼로 바뀌어 빛을 뿜습니다. Dancing Chrome과 함께 쓰기 좋아요.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "desktopCapture",
    "offscreen",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Mirrorball Cursor",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/mirrorball.js"],
      "css": ["src/content/mirrorball.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "commands": {
    "toggle-mirrorball": {
      "suggested_key": {
        "default": "Alt+Shift+M",
        "mac": "Alt+Shift+M"
      },
      "description": "미러볼 커서 켜기/끄기"
    }
  }
}
